<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme colors -->
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="TertiaryBackgroundBrush" Color="#2D2D30"/>
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#F1F1F1"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#2D2D30"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#2899F5"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1177BB"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#094771"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="TrackBrush" Color="#4A4A4F"/>
    <SolidColorBrush x:Key="ThumbBackgroundBrush" Color="#3C3C40"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF99A4"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFC83D"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#6CCB5F"/>

</ResourceDictionary>
