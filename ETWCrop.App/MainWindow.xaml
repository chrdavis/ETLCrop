<Window x:Class="ETWCrop.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ETWCrop.App"
        Title="ETL Crop" Height="540" Width="720"
        MinHeight="480" MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Icon="ETLCrop.ico"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        Foreground="{DynamicResource PrimaryForegroundBrush}"
        FontFamily="Segoe UI" FontSize="12"
        AllowDrop="True"
        DragOver="Window_DragOver" Drop="Window_Drop">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Input ETL:" VerticalAlignment="Center" Margin="0,0,8,8" />
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="InputPathBox"
                 VerticalAlignment="Center" Margin="0,0,8,8"
                 LostFocus="InputPathBox_LostFocus" />
        <Button Grid.Row="0" Grid.Column="2" Content="Browse..."
                Padding="12,4" Margin="0,0,0,8" Click="BrowseInput_Click" />

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Output ETL:" VerticalAlignment="Center" Margin="0,0,8,8" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="OutputPathBox"
                 VerticalAlignment="Center" Margin="0,0,8,8" />
        <Button Grid.Row="1" Grid.Column="2" Content="Browse..."
                Padding="12,4" Margin="0,0,0,8" Click="BrowseOutput_Click" />

        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                   x:Name="TraceInfoText" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Text="Drag an ETL file here, or browse, to load its duration." />

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="Start (ms):" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="StartBox" Width="110" VerticalAlignment="Center"
                     TextChanged="StartBox_TextChanged"
                     ToolTip="Milliseconds relative to the trace start. Leave blank for the beginning." />
            <TextBlock Text="Stop (ms):" VerticalAlignment="Center" Margin="24,0,8,0" />
            <TextBox x:Name="StopBox" Width="110" VerticalAlignment="Center"
                     TextChanged="StopBox_TextChanged"
                     ToolTip="Milliseconds relative to the trace start. Leave blank for the end." />
        </StackPanel>

        <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8"
              x:Name="SlidersPanel" IsEnabled="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Window" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextStyle}" Margin="0,0,8,0" />
            <local:RangeSlider Grid.Column="1" x:Name="TimeRangeSlider" Maximum="0"
                               VerticalAlignment="Center" RangeChanged="RangeSlider_RangeChanged" />
        </Grid>

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,8">
            <CheckBox x:Name="KeepMetadataCheck" IsChecked="True" Margin="0,0,0,4"
                      Content="Keep process / thread / module events so CPU and memory stacks stay valid (recommended)" />
            <CheckBox x:Name="ClampWindowCheck" IsChecked="True" Margin="0,0,0,4"
                      Content="End the cropped trace at the Stop time (re-time end-of-trace rundown; recommended)" />
            <CheckBox x:Name="RebaseCheck" IsChecked="False"
                      Content="Trim leading time by shifting the window to start at zero (advanced; remains valid in Windows Performance Analyzer)" />
        </StackPanel>

        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,8">
            <Button x:Name="CancelButton" Content="Cancel" Padding="24,6" Margin="0,0,8,0"
                    IsCancel="True" Visibility="Collapsed" Click="CancelButton_Click" />
            <Button x:Name="CropButton" Content="Crop" Padding="24,6"
                    IsDefault="True" Click="CropButton_Click" />
        </StackPanel>

        <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" x:Name="Progress" Height="14" Minimum="0" Maximum="100" />
            <TextBlock Grid.Column="1" x:Name="ProgressText" VerticalAlignment="Center"
                       MinWidth="44" TextAlignment="Right" Margin="8,0,0,0" />
        </Grid>

        <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3"
                Background="{DynamicResource SecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="3" Padding="8" Margin="0,4,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="StatusText" TextWrapping="Wrap"
                           Text="Choose an input ETL file, a destination, and a time window, then click Crop." />
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="3"
                   Style="{StaticResource CaptionTextStyle}" Margin="0,8,0,0" TextWrapping="Wrap"
                   Text="Times are milliseconds relative to the start of the trace (the same timeline PerfView shows)." />
    </Grid>
</Window>
