<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	 xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="ETLCrop" Manufacturer="ETLCrop" Version="$(var.Version)" UpgradeCode="E93B003F-0AA2-46FC-8E45-06833918A37B" InstallerVersion="500">
	<MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
	<MediaTemplate EmbedCab="yes" />

	<!-- Application icon for Add/Remove Programs -->
	<Icon Id="ETLCrop.ico" SourceFile="$(var.ETLCrop.App.ProjectDir)ETLCrop.ico" />
	<Property Id="ARPPRODUCTICON" Value="ETLCrop.ico" />

	<Feature Id="Main">
	  <ComponentGroupRef Id="ProductComponents" />
	  <ComponentGroupRef Id="CliComponents" />
	  <ComponentRef Id="ProgramMenuShortcut" />
	</Feature>

	<!-- UI with welcome screen, install directory selection, and completion dialog -->
	<Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
	<WixVariable Id="WixUIBannerBmp" Value="banner.bmp" />
	<WixVariable Id="WixUIDialogBmp" Value="dialog.bmp" />
	<ui:WixUI Id="WixUI_InstallDir" />

	<!-- Skip the license agreement dialog -->
	<UI>
	  <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Order="2" Condition="1" />
	  <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2" Condition="1" />
	</UI>
  </Package>

  <Fragment>
	<StandardDirectory Id="ProgramFiles6432Folder">
	  <Directory Id="INSTALLFOLDER" Name="ETLCrop" />
	</StandardDirectory>
  </Fragment>

  <Fragment>
	<StandardDirectory Id="ProgramMenuFolder">
	  <Directory Id="ApplicationProgramsFolder" Name="ETLCrop" />
	</StandardDirectory>
  </Fragment>

  <Fragment>
	<!-- Harvest every file the WPF app produces (exe + all dependency DLLs and runtime config),
		 so the installed app is self-contained without hand-listing each assembly. -->
	<ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
	  <Files Include="$(var.ETLCrop.App.TargetDir)**" />
	</ComponentGroup>
  </Fragment>

  <Fragment>
	<!-- Ship the command-line tool (etlcrop.exe) alongside the app. Only the CLI's own
		 files are listed here; the shared ETLCrop.Core / TraceEvent assemblies are
		 already installed from the app output above. -->
	<ComponentGroup Id="CliComponents" Directory="INSTALLFOLDER">
	  <Component>
		<File Source="$(var.ETLCrop.Cli.TargetDir)etlcrop.exe" />
	  </Component>
	  <Component>
		<File Source="$(var.ETLCrop.Cli.TargetDir)etlcrop.dll" />
	  </Component>
	  <Component>
		<File Source="$(var.ETLCrop.Cli.TargetDir)etlcrop.runtimeconfig.json" />
	  </Component>
	  <Component>
		<File Source="$(var.ETLCrop.Cli.TargetDir)etlcrop.deps.json" />
	  </Component>
	</ComponentGroup>
  </Fragment>

  <Fragment>
	<Component Id="ProgramMenuShortcut" Guid="21B6812A-E613-4E9E-994D-1A1987DD1079" Directory="ApplicationProgramsFolder">
	  <Shortcut Id="ApplicationStartMenuShortcut"
				Name="ETLCrop"
				Description="Crop an ETL trace to a time window"
				Target="[INSTALLFOLDER]ETLCrop.App.exe"
				WorkingDirectory="INSTALLFOLDER" />
	  <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
	  <RegistryValue Root="HKCU" Key="Software\ETLCrop" Name="installed" Type="integer" Value="1" KeyPath="yes" />
	</Component>
  </Fragment>

</Wix>
