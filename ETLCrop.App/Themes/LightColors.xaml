<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light theme colors -->
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="TertiaryBackgroundBrush" Color="#E9E9E9"/>
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#5A5A5A"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#106EBE"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#005A9E"/>
    <SolidColorBrush x:Key="HoverBrush" Color="#E5F1FB"/>
    <SolidColorBrush x:Key="TrackBrush" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="ThumbBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#C42B1C"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#9D5D00"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#0F7B0F"/>

</ResourceDictionary>
